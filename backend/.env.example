# ─── Backend CIUDAD — Negocios Inmobiliarios ────────────────────────────────
# Copiá este archivo a backend/.env y completá los valores.

# Servidor
PORT=8000
CORS_ORIGINS=http://localhost:5173
DATABASE_URL=sqlite:///./ciudad.db

# JWT — generar con: python -c "import secrets;print(secrets.token_urlsafe(32))"
SECRET_KEY=ciudad-dev-secret-change-me

# ─── Telegram (agente IA) ───────────────────────────────────────────────────
# Obtener token con @BotFather en Telegram.
# El bot atiende dos audiencias:
#   • Chats vinculados a un User.telegram_chat_id → agente ADMIN (con permisos
#     según el rol del usuario en la BD).
#   • Cualquier otro chat → agente PÚBLICO de leads (CRM + tool consultar_propiedades).
TELEGRAM_BOT_TOKEN=123456:ABC...

# Fallback de admin para desarrollo (CSV de chat_id que entran como rol "admin"
# sin estar vinculados a un User). En producción preferir bindings en BD vía
# POST /api/agente/admin/bind-chat.
# Para conocer tu chat_id, hablale al bot @userinfobot en Telegram.
TELEGRAM_ADMIN_CHATS=

# ─── Anthropic (LLM tool-calling) ───────────────────────────────────────────
# Sin esto, el agente admin igual responde a comandos /buscar, /info, etc.
# El agente público requiere ANTHROPIC_API_KEY para funcionar (usa Sonnet).
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── Email (SMTP) — para comprobantes ───────────────────────────────────────
# Si no se configura, los PDFs igual se generan y quedan descargables.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CIUDAD. <noreply@tu-dominio.com>
SMTP_TLS=true

# ─── Tokko Broker (sync de propiedades en venta) ────────────────────────────
TOKKO_API_KEY=
TOKKO_API_URL=https://www.tokkosoftware.com/api/v1

# ─── Instagram (preparado, no activo) ───────────────────────────────────────
INSTAGRAM_VERIFY_TOKEN=ciudad_verify_token
INSTAGRAM_PAGE_ACCESS_TOKEN=
